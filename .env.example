# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Blog API (MCP 서버에서 사용)
BLOG_API_KEY=blog-your-generated-key

# ISR (Incremental Static Regeneration)
# On-Demand Revalidation을 위한 보안 토큰
# 생성 예시: openssl rand -base64 32
ISR_BYPASS_TOKEN=your-secret-bypass-token
SITE_URL=https://your-site.vercel.app

# Topic-aware Telegram delivery (forum supergroup, my-blog topic)
# Forward-looking: 자동 알림 routine이 추가될 때 사용한다.
# CHAT_ID는 음수(supergroup), THREAD_ID는 forum topic id.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-1003853102198
TELEGRAM_THREAD_ID=98
