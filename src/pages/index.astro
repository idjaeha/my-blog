---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostList from "@/components/blog/PostList.astro";
import CategoryList from "@/components/blog/CategoryList.astro";
import { contentService } from "@/lib/content";
import { SITE } from "@/lib/constants";
import { t, getLocalizedPath } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "ko";
const allPosts = await contentService.getAllPosts(locale);
const latestPosts = allPosts.slice(0, 5);
---

<BaseLayout title={SITE.title} description={SITE.description} locale={locale}>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <div class="space-y-4">
      <h1 class="text-4xl font-bold tracking-tight">{SITE.title}</h1>
      <p class="text-lg text-muted-foreground">{SITE.description}</p>
    </div>

    <section class="mt-12">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-2xl font-semibold">{t("blog.latestPosts", locale)}</h2>
        <a
          href={getLocalizedPath("/blog", locale)}
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {t("blog.viewAll", locale)} &rarr;
        </a>
      </div>
      <PostList posts={latestPosts} locale={locale} />
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-2xl font-semibold">
        {t("blog.categories", locale)}
      </h2>
      <CategoryList locale={locale} itemClass="px-4 py-2" />
    </section>
  </section>
</BaseLayout>
