---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/constants";
import type { Locale } from "@/i18n";

const locale: Locale = "ko";

interface ProjectLink {
  label: string;
  href: string;
}

interface Project {
  name: string;
  tagline: string;
  description: string;
  links: ProjectLink[];
}

const projects: Project[] = [
  {
    name: "daily-feed",
    tagline: "매일 두 번, 한국어 뉴스 핵심을 카드로 정리해 주는 사이트.",
    description:
      "오전·저녁마다 종합 뉴스, 따로 한 번 더 AI 뉴스. 글을 쓰는 건 사람이 아니라 LLM 파이프라인이다.",
    links: [{ label: "Live", href: "https://daily-feed-virid.vercel.app" }],
  },
  {
    name: "idea-cycles",
    tagline: "매일 새벽, 새 웹 기술로 30분짜리 데모 한 편을 자동으로 만든다.",
    description:
      "LLM 파이프라인이 무료로 쓸 수 있는 신기술을 하루에 하나씩 골라 자체완결 데모를 짠다. 같은 디자인 톤으로 누적된 카탈로그가 매일 한 칸씩 늘어난다.",
    links: [
      { label: "Live", href: "https://idea-cycles.vercel.app" },
      {
        label: "Series",
        href: "/blog/series/%EC%95%84%EC%9D%B4%EB%94%94%EC%96%B4%20%EC%82%AC%EC%9D%B4%ED%81%B4%20%ED%9A%8C%EA%B3%A0",
      },
    ],
  },
  {
    name: "mini-arcade",
    tagline: "단판으로 즐기는 가벼운 게임 모음, 첫 게임은 알까기.",
    description:
      "한지·단청·바둑판 톤으로 한국 전통 미감을 살린 미니게임 사이트. 한 판이 짧고 다시 시작하기 쉬운 캐주얼 톤.",
    links: [],
  },
  {
    name: "my-blog",
    tagline: "이 블로그 — 한·영 다국어 개인 기술 블로그.",
    description:
      "회고와 기술 글을 모은다. 글은 LLM이 직접 작성·발행하는 흐름으로 운영해, 사람은 검토와 톤 조정에만 손을 댄다.",
    links: [
      { label: "Live", href: "https://my-blog.site" },
      { label: "GitHub", href: "https://github.com/idjaeha/my-blog" },
    ],
  },
  {
    name: "playground-ops",
    tagline:
      "여러 자동화 작업의 스케줄을 한 파일로 관리하는 개인용 운영 레이어.",
    description:
      "흩어진 정기 작업들을 한 곳에서 등록·점검한다. 매일 상태 점검 결과가 텔레그램으로 떨어져 어디가 멈췄는지 바로 알 수 있다.",
    links: [],
  },
  {
    name: "telegram-claude-bot",
    tagline:
      "텔레그램 채팅으로 데스크톱의 Claude Code를 원격 조작하는 1인용 봇.",
    description:
      "출퇴근길이나 외출 중에도 짧은 작업·빌드 확인·간단한 커밋을 처리할 수 있다. 한 봇으로 여러 프로젝트를 채팅 토픽 단위로 나눠 부린다.",
    links: [
      {
        label: "Series",
        href: "/blog/series/%ED%85%94%EB%A0%88%EA%B7%B8%EB%9E%A8%20%EB%B4%87%20%EA%B0%9C%EB%B0%9C%20%EC%9D%BC%EC%A7%80",
      },
    ],
  },
];
---

<BaseLayout
  title={`Projects - ${SITE.title}`}
  description="재하가 운영 중인 개인 프로젝트 모음."
  locale={locale}
>
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Projects</h1>
    <p class="mb-8 text-muted-foreground">운영 중인 6개 개인 프로젝트.</p>

    <div class="grid gap-4">
      {
        projects.map((p) => (
          <article class="rounded-md border bg-card p-5 text-card-foreground transition-colors hover:bg-secondary/40">
            <h2 class="mb-1 text-lg font-semibold">
              <code class="rounded bg-muted px-1.5 py-0.5 text-sm">
                {p.name}
              </code>
            </h2>
            <p class="mb-2 text-sm font-medium">{p.tagline}</p>
            <p class="mb-3 text-sm text-muted-foreground">{p.description}</p>
            {p.links.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {p.links.map((l) => (
                  <a
                    href={l.href}
                    class="rounded-md bg-secondary px-2.5 py-1 text-xs text-secondary-foreground transition-colors hover:bg-secondary/80"
                    target={l.href.startsWith("http") ? "_blank" : undefined}
                    rel={l.href.startsWith("http") ? "noopener" : undefined}
                  >
                    {l.label}
                  </a>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
