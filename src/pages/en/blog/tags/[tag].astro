---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostList from "@/components/blog/PostList.astro";
import TagList from "@/components/blog/TagList.astro";
import { contentService } from "@/lib/content";
import { t } from "@/i18n";
import type { Locale } from "@/i18n";
import { SITE } from "@/lib/constants";

export async function getStaticPaths() {
  const locale: Locale = "en";
  const tags = await contentService.getAllTags(locale);

  return tags.map((tag) => ({
    params: { tag },
  }));
}

const locale: Locale = "en";
const { tag } = Astro.params;
const posts = await contentService.getPostsByTag(tag!, locale);
const allTags = await contentService.getAllTags(locale);
---

<BaseLayout
  title={`${tag} - ${t("blog.tags", locale)} - ${SITE.title}`}
  description={`${t("blog.taggedWith", locale)}: ${tag}`}
  locale={locale}
>
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">
      #{tag}
    </h1>
    <p class="mb-6 text-muted-foreground">
      {posts.length}
      {t("blog.postsCount", locale)}
    </p>

    <div class="mb-8">
      <TagList tags={allTags} locale={locale} activeTag={tag} />
    </div>

    <PostList posts={posts} locale={locale} />
  </section>
</BaseLayout>
