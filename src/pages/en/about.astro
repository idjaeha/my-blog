---
import PageLayout from "@/layouts/PageLayout.astro";
import { t } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "en";
---

<PageLayout
  title={t("about.title", locale)}
  description={t("about.description", locale)}
  locale={locale}
>
  <h1 class="mb-6 text-3xl font-bold tracking-tight">Jaeha Yi</h1>

  <div class="prose prose-neutral dark:prose-invert max-w-none">
    <p>
      Hello, I'm Jaeha Yi. I'm a developer passionate about software
      development.
    </p>

    <h2>Interests</h2>
    <ul>
      <li>Web Frontend Development</li>
      <li>User Experience (UX) Design</li>
      <li>Accessibility</li>
      <li>Performance Optimization</li>
    </ul>

    <h2>About This Blog</h2>
    <p>
      This blog is built with Astro, React, and Tailwind CSS. It's a space for
      sharing TIL notes, project retrospectives, technical articles, and
      tutorials.
    </p>
  </div>
</PageLayout>
