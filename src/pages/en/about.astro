---
import PageLayout from "@/layouts/PageLayout.astro";
import { t } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "en";
---

<PageLayout
  title={t("about.title", locale)}
  description={t("about.description", locale)}
  locale={locale}
>
  <h1 class="mb-6 text-3xl font-bold tracking-tight">ID001</h1>

  <div class="mdx-content">
    <p>
      Hello, I'm ID001. I'm a developer passionate about software development.
    </p>

    <h2>Interests</h2>
    <ul>
      <li>Platform Engineering & Backend Architecture</li>
      <li>Data Engineering & Search Systems</li>
      <li>AWS Infrastructure Operations & Cost Optimization</li>
      <li>Technical Leadership & Team Management</li>
      <li>Collaboration Culture, Documentation & Productive Ways of Working</li>
    </ul>

    <h2>About This Blog</h2>
    <p>
      This blog is built with Astro, React, and Tailwind CSS. It's a space for
      sharing TIL notes, project retrospectives, technical articles, and
      tutorials. The source code is available on <a
        href="https://github.com/idjaeha/my-blog"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >.
    </p>

    <h2>Contact</h2>
    <ul>
      <li>
        Email: <a href="mailto:jaehayi.id@gmail.com">jaehayi.id@gmail.com</a>
      </li>
      <li>
        LinkedIn: <a
          href="https://www.linkedin.com/in/jaeha-yi-/"
          target="_blank"
          rel="noopener noreferrer">linkedin.com/in/jaeha-yi-</a
        >
      </li>
    </ul>
  </div>
</PageLayout>
