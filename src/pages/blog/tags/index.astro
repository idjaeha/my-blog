---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagList from "@/components/blog/TagList.astro";
import { contentService } from "@/lib/content";
import { t } from "@/i18n";
import type { Locale } from "@/i18n";
import { SITE } from "@/lib/constants";

const locale: Locale = "ko";
const tags = await contentService.getAllTags(locale);
const allPosts = await contentService.getAllPosts(locale);

const tagCounts = new Map<string, number>();
for (const tag of tags) {
  const count = allPosts.filter((p) => p.tags.includes(tag)).length;
  tagCounts.set(tag, count);
}
---

<BaseLayout
  title={`${t("blog.tags", locale)} - ${SITE.title}`}
  description={t("blog.tags", locale)}
  locale={locale}
>
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-6 text-3xl font-bold tracking-tight">
      {t("blog.tags", locale)}
    </h1>

    <div class="flex flex-wrap gap-3">
      {
        tags.map((tag) => (
          <a
            href={`/blog/tags/${tag}`}
            class="flex items-center gap-1.5 rounded-md bg-secondary px-3 py-1.5 text-sm text-secondary-foreground transition-colors hover:bg-secondary/80"
          >
            <span>{tag}</span>
            <span class="rounded-full bg-muted px-1.5 py-0.5 text-xs text-muted-foreground">
              {tagCounts.get(tag)}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
