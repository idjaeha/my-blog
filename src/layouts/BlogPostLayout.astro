---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Locale, t } from "@/i18n";
import { CATEGORIES, SITE } from "@/lib/constants";
import { formatDate, getReadingTime } from "@/lib/utils";
import TableOfContents from "@/components/islands/TableOfContents";
import ShareButton from "@/components/islands/ShareButton";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    updatedDate?: string;
    category: keyof typeof CATEGORIES;
    tags?: string[];
    image?: string;
    coverImage?: ImageMetadata;
    draft?: boolean;
  };
  locale: Locale;
  rawContent?: string;
}

const { frontmatter, locale, rawContent } = Astro.props;
const pubDate = new Date(frontmatter.date);
const updatedDate = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate)
  : undefined;
const readingTime = rawContent ? getReadingTime(rawContent, locale) : undefined;
const categoryLabel =
  CATEGORIES[frontmatter.category]?.[locale] ?? frontmatter.category;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: SITE.author,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL.href,
  },
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  type="article"
  publishedDate={pubDate.toISOString()}
  updatedDate={updatedDate?.toISOString()}
  locale={locale}
>
  <div
    class="relative mx-auto max-w-5xl xl:grid xl:grid-cols-[1fr_200px] xl:gap-8 xl:px-4"
  >
    <article class="mx-auto max-w-3xl px-4 py-10 xl:mx-0">
      <header class="mb-8 space-y-3">
        <div
          class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
        >
          <div class="flex flex-1 flex-wrap items-center gap-2">
            <span>{categoryLabel}</span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={pubDate.toISOString()}>
              {t("blog.publishedOn", locale)}
              {formatDate(pubDate, locale)}
            </time>
            {
              updatedDate && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <time datetime={updatedDate.toISOString()}>
                    {t("blog.updatedOn", locale)}{" "}
                    {formatDate(updatedDate, locale)}
                  </time>
                </>
              )
            }
            {
              readingTime && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <span>
                    {readingTime}
                    {t("blog.minuteRead", locale)}
                  </span>
                </>
              )
            }
          </div>
          <ShareButton
            client:idle
            url={canonicalURL.href}
            title={frontmatter.title}
            locale={locale}
          />
        </div>

        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {frontmatter.title}
        </h1>

        {
          frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                <span class="rounded-md bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      {
        frontmatter.coverImage && (
          <Image
            src={frontmatter.coverImage}
            alt={frontmatter.title}
            class="mb-8 w-full rounded-lg"
          />
        )
      }

      <div class="mdx-content">
        <slot />
      </div>

      <slot name="post-nav" />
    </article>
    <aside class="hidden py-10 xl:block">
      <TableOfContents client:idle />
    </aside>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
