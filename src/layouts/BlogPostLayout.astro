---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Locale, t } from "@/i18n";
import { CATEGORIES, SITE } from "@/lib/constants";
import { formatDate, getReadingTime } from "@/lib/utils";
import TableOfContents from "@/components/islands/TableOfContents";
import ShareButton from "@/components/islands/ShareButton";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    updatedDate?: string;
    category: keyof typeof CATEGORIES;
    tags?: string[];
    image?: string;
    coverImage?: string;
    draft?: boolean;
    hasTranslations?: string[];
    translatedFrom?: string;
  };
  locale: Locale;
  rawContent?: string;
}

const { frontmatter, locale, rawContent } = Astro.props;
const pubDate = new Date(frontmatter.date);
const updatedDate = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate)
  : undefined;
const readingTime = rawContent ? getReadingTime(rawContent, locale) : undefined;
const categoryLabel =
  CATEGORIES[frontmatter.category]?.[locale] ?? frontmatter.category;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Translation links
const alternateLocale: Locale = locale === "ko" ? "en" : "ko";
const hasAlternateTranslation =
  frontmatter.hasTranslations?.includes(alternateLocale);
const alternateUrl = hasAlternateTranslation
  ? Astro.url.pathname.replace(
      locale === "en" ? "/en" : "",
      locale === "en" ? "" : "/en",
    )
  : null;

const ogImageURL = frontmatter.image
  ? new URL(frontmatter.image, Astro.site).href
  : new URL("/og-default.png", Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": frontmatter.category === "tutorial" ? "TechArticle" : "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: SITE.author.name,
    ...(SITE.author.url && { url: SITE.author.url }),
    ...(SITE.author.social && {
      sameAs: [
        SITE.author.social.github?.startsWith("http")
          ? SITE.author.social.github
          : SITE.author.social.github
            ? `https://github.com/${SITE.author.social.github}`
            : null,
        SITE.author.social.twitter?.startsWith("http")
          ? SITE.author.social.twitter
          : SITE.author.social.twitter
            ? `https://twitter.com/${SITE.author.social.twitter.replace("@", "")}`
            : null,
        SITE.author.social.linkedin,
      ].filter(Boolean),
    }),
  },
  publisher: {
    "@type": "Organization",
    name: SITE.title,
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.svg", Astro.site).href,
    },
  },
  image: {
    "@type": "ImageObject",
    url: ogImageURL,
  },
  ...(frontmatter.tags &&
    frontmatter.tags.length > 0 && {
      keywords: frontmatter.tags.join(", "),
    }),
  articleSection: categoryLabel,
  inLanguage: locale === "ko" ? "ko-KR" : "en-US",
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL.href,
  },
  // Translation information
  ...(frontmatter.translatedFrom && {
    translationOfWork: {
      "@type":
        frontmatter.category === "tutorial" ? "TechArticle" : "BlogPosting",
      "@id": new URL(
        `/${frontmatter.translatedFrom.replace(/^ko\//, "")}`,
        Astro.site,
      ).href,
      inLanguage: "ko-KR",
    },
  }),
  ...(hasAlternateTranslation &&
    alternateUrl && {
      workTranslation: {
        "@type":
          frontmatter.category === "tutorial" ? "TechArticle" : "BlogPosting",
        "@id": new URL(alternateUrl, Astro.site).href,
        inLanguage: alternateLocale === "ko" ? "ko-KR" : "en-US",
      },
    }),
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  type="article"
  publishedDate={pubDate.toISOString()}
  updatedDate={updatedDate?.toISOString()}
  locale={locale}
  tags={frontmatter.tags}
  category={categoryLabel}
  draft={frontmatter.draft}
>
  <div
    class="relative mx-auto max-w-5xl xl:grid xl:grid-cols-[1fr_200px] xl:gap-8 xl:px-4"
  >
    <article class="mx-auto max-w-3xl px-4 py-10 xl:mx-0">
      <header class="mb-8 space-y-3">
        <div
          class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
        >
          <div class="flex flex-1 flex-wrap items-center gap-2">
            <span>{categoryLabel}</span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={pubDate.toISOString()}>
              {t("blog.publishedOn", locale)}
              {formatDate(pubDate, locale)}
            </time>
            {
              updatedDate && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <time datetime={updatedDate.toISOString()}>
                    {t("blog.updatedOn", locale)}{" "}
                    {formatDate(updatedDate, locale)}
                  </time>
                </>
              )
            }
            {
              readingTime && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <span>
                    {readingTime}
                    {t("blog.minuteRead", locale)}
                  </span>
                </>
              )
            }
          </div>
          <ShareButton
            client:idle
            url={canonicalURL.href}
            title={frontmatter.title}
            locale={locale}
          />
        </div>

        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {frontmatter.title}
        </h1>

        {
          frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                <span class="rounded-md bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      {
        hasAlternateTranslation && alternateUrl && (
          <div class="mb-6 rounded-lg border border-primary/20 bg-primary/5 px-4 py-3">
            <div class="flex items-center gap-2 text-sm">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="opacity-70"
              >
                <path d="M5 8h14M5 12h14M5 16h14" />
                <path d="M9 3v18" />
              </svg>
              <span class="opacity-70">
                {locale === "ko"
                  ? "This post is also available in English:"
                  : "이 글은 한국어로도 읽을 수 있습니다:"}
              </span>
              <a
                href={alternateUrl}
                class="font-medium text-primary underline decoration-primary/50 underline-offset-2 transition-colors hover:decoration-primary"
              >
                {t(
                  locale === "ko" ? "blog.readInEnglish" : "blog.readInKorean",
                  locale,
                )}
              </a>
            </div>
          </div>
        )
      }

      {
        frontmatter.coverImage && (
          <img
            src={frontmatter.coverImage}
            alt={frontmatter.title}
            class="mb-8 w-full rounded-lg"
          />
        )
      }

      <div class="mdx-content">
        <slot />
      </div>

      <slot name="post-nav" />
    </article>
    <aside class="hidden py-10 xl:block">
      <TableOfContents client:idle />
    </aside>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {
    /* Auto-initialize mermaid for Supabase posts (HTML <pre class="mermaid"> blocks) */
  }
  <script src="../scripts/mermaid.ts"></script>
  {/* Code block copy buttons */}
  <script src="../scripts/code-block.ts"></script>
</BaseLayout>
