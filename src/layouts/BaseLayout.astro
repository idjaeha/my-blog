---
import "@/styles/globals.css";
import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { type Locale, t, getLocalizedPath } from "@/i18n";
import ThemeToggle from "@/components/islands/ThemeToggle";
import MobileNav from "@/components/islands/MobileNav";
import Analytics from "@vercel/analytics/astro";
import OrganizationSchema from "@/components/seo/OrganizationSchema.astro";
import WebSiteSchema from "@/components/seo/WebSiteSchema.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string;
  updatedDate?: string;
  locale?: Locale;
  alternateLocale?: Locale;
  alternatePath?: string;
  tags?: string[];
  category?: string;
  draft?: boolean;
}

const {
  title,
  description,
  image,
  type,
  publishedDate,
  updatedDate,
  locale = "ko",
  alternateLocale,
  alternatePath,
  tags,
  category,
  draft,
} = Astro.props;

const mobileNavLinks = [
  { href: getLocalizedPath("/", locale), label: t("nav.home", locale) },
  { href: getLocalizedPath("/blog", locale), label: t("nav.blog", locale) },
  {
    href: getLocalizedPath("/projects", locale),
    label: t("nav.projects", locale),
  },
  { href: getLocalizedPath("/about", locale), label: t("nav.about", locale) },
];
---

<!doctype html>
<html lang={locale === "ko" ? "ko" : "en"}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      updatedDate={updatedDate}
      locale={locale}
      alternateLocale={alternateLocale}
      alternatePath={alternatePath}
      tags={tags}
      category={category}
      draft={draft}
    />
    <OrganizationSchema />
    <WebSiteSchema locale={locale} />
    <Analytics />
  </head>
  <body
    class="min-h-dvh flex flex-col bg-background text-foreground antialiased"
  >
    <Header locale={locale}>
      <ThemeToggle client:load slot="theme-toggle" />
      <MobileNav
        client:load
        slot="mobile-nav"
        locale={locale}
        links={mobileNavLinks}
      />
    </Header>
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Locale detection and auto-redirect -->
    <script is:inline define:vars={{ currentLocale: locale }}>
      (function () {
        const LOCALE_PREF_KEY = "preferred-locale";
        const REDIRECT_ATTEMPTED_KEY = "locale-redirect-attempted";

        // Skip if redirect was already attempted in this session
        if (sessionStorage.getItem(REDIRECT_ATTEMPTED_KEY)) {
          return;
        }

        // Check for saved preference
        let preferredLocale = localStorage.getItem(LOCALE_PREF_KEY);

        // If no saved preference, detect from browser
        if (!preferredLocale) {
          const browserLang = navigator.language || navigator.userLanguage;
          // Match English variants (en, en-US, en-GB, etc.)
          preferredLocale = browserLang.toLowerCase().startsWith("en")
            ? "en"
            : "ko";

          // Save the detected preference
          localStorage.setItem(LOCALE_PREF_KEY, preferredLocale);
        }

        // Only redirect if:
        // 1. Preferred locale differs from current locale
        // 2. We haven't redirected yet in this session
        if (preferredLocale !== currentLocale) {
          const currentPath = window.location.pathname;
          let targetPath;

          if (preferredLocale === "en" && !currentPath.startsWith("/en")) {
            // Redirect Korean → English
            targetPath = "/en" + currentPath;
          } else if (
            preferredLocale === "ko" &&
            currentPath.startsWith("/en")
          ) {
            // Redirect English → Korean
            targetPath = currentPath.replace(/^\/en/, "") || "/";
          }

          if (targetPath) {
            // Mark that we attempted redirect
            sessionStorage.setItem(REDIRECT_ATTEMPTED_KEY, "1");

            // Check if target page exists by doing a HEAD request
            fetch(targetPath, { method: "HEAD" })
              .then((response) => {
                if (response.ok) {
                  window.location.href = targetPath;
                }
              })
              .catch(() => {
                // Target doesn't exist, stay on current page
              });
          }
        }

        // Listen for manual language switch (from Header component)
        window.addEventListener("languageSwitched", (event) => {
          const newLocale = event.detail.locale;
          localStorage.setItem(LOCALE_PREF_KEY, newLocale);
        });
      })();
    </script>
  </body>
</html>
