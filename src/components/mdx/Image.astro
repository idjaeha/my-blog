---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-6">
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full rounded-lg shadow-md"
  />
  {
    caption && (
      <figcaption class="mt-2 text-center text-sm text-muted-foreground">
        {caption}
      </figcaption>
    )
  }
</figure>
