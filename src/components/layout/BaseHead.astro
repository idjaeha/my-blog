---
import { SITE } from "@/lib/constants";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string;
  updatedDate?: string;
  locale?: "ko" | "en";
  alternateLocale?: "ko" | "en";
  alternatePath?: string;
  tags?: string[];
  category?: string;
  draft?: boolean;
}

const {
  title,
  description,
  image = "/og-default.png",
  type = "website",
  publishedDate,
  updatedDate,
  locale = "ko",
  alternateLocale,
  alternatePath,
  tags,
  category,
  draft = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const ogLocale = locale === "ko" ? "ko_KR" : "en_US";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author.name} />
{tags && tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
{draft && <meta name="robots" content="noindex, nofollow" />}
<meta
  name="theme-color"
  content="#ffffff"
  media="(prefers-color-scheme: light)"
/>
<meta
  name="theme-color"
  content="#0a0a0a"
  media="(prefers-color-scheme: dark)"
/>
<link rel="canonical" href={canonicalURL.href} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL.href} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={SITE.title} />
{
  type === "article" && SITE.author.url && (
    <meta property="article:author" content={SITE.author.url} />
  )
}
{
  type === "article" && category && (
    <meta property="article:section" content={category} />
  )
}
{
  type === "article" &&
    tags &&
    tags.map((tag) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL.href} />
{
  SITE.author.social?.twitter && (
    <meta name="twitter:site" content={SITE.author.social.twitter} />
  )
}
{
  SITE.author.social?.twitter && (
    <meta name="twitter:creator" content={SITE.author.social.twitter} />
  )
}

<!-- Article dates -->
{
  publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )
}
{updatedDate && <meta property="article:modified_time" content={updatedDate} />}

<!-- Alternate language (hreflang) -->
<!-- Current page language -->
<link
  rel="alternate"
  hreflang={locale === "ko" ? "ko" : "en"}
  href={canonicalURL.href}
/>

<!-- Alternate language version (if exists) -->
{
  alternateLocale && alternatePath && (
    <link
      rel="alternate"
      hreflang={alternateLocale === "ko" ? "ko" : "en"}
      href={new URL(alternatePath, Astro.site).href}
    />
  )
}

<!-- x-default: use Korean as default -->
<link
  rel="alternate"
  hreflang="x-default"
  href={locale === "ko"
    ? canonicalURL.href
    : new URL(Astro.url.pathname.replace(/^\/en/, "") || "/", Astro.site).href}
/>

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.title} (한국어)`}
  href={new URL("/rss.xml", Astro.site).href}
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.title} (English)`}
  href={new URL("/en/rss.xml", Astro.site).href}
/>

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- FOUC prevention: apply dark mode before render -->
<script is:inline>
  (function () {
    const theme = localStorage.getItem("theme");
    if (
      theme === "dark" ||
      (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
    ) {
      document.documentElement.classList.add("dark");
    }
  })();
</script>
