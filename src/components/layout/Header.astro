---
import { type Locale, t, getLocalizedPath } from "@/i18n";
import { SITE } from "@/lib/constants";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const alternateLocale = locale === "ko" ? "en" : "ko";
const alternateLabel = locale === "ko" ? "EN" : "한국어";

const navLinks = [
  { href: getLocalizedPath("/", locale), label: t("nav.home", locale) },
  { href: getLocalizedPath("/blog", locale), label: t("nav.blog", locale) },
  { href: getLocalizedPath("/about", locale), label: t("nav.about", locale) },
];

function getAlternatePath(currentPath: string): string {
  if (locale === "ko") {
    return `/en${currentPath}`;
  }
  return currentPath.replace(/^\/en/, "") || "/";
}

const alternatePath = getAlternatePath(Astro.url.pathname);
---

<header
  class="border-b border-border bg-background/95 backdrop-blur-sm supports-[backdrop-filter]:bg-background/60"
>
  <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-4">
    <a
      href={getLocalizedPath("/", locale)}
      class="text-lg font-semibold tracking-tight"
    >
      {SITE.title}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-muted-foreground transition-colors hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }

      <a
        href={alternatePath}
        class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        aria-label={`Switch to ${alternateLabel}`}
      >
        {alternateLabel}
      </a>

      <!-- Theme toggle island slot -->
      <slot name="theme-toggle" />
    </nav>

    <!-- Mobile nav placeholder -->
    <div class="flex items-center gap-2 md:hidden">
      <slot name="theme-toggle" />
      <slot name="mobile-nav" />
    </div>
  </div>
</header>
